# Guni API — Environment Config
# Copy this to .env and fill in your values

# ── LLM Layer ────────────────────────────────────────────────────────────────
# Get your key at https://console.anthropic.com
# Leave blank to run heuristics-only mode (free, still very effective)
ANTHROPIC_API_KEY=sk-ant-...

# ── API Authentication ────────────────────────────────────────────────────────
# Comma-separated list of valid API keys for your customers
# Leave blank to run in open mode (good for local dev)
GUNI_API_KEYS=

# ── Rate Limiting ─────────────────────────────────────────────────────────────
# Max requests per minute per API key (default: 60)
GUNI_RATE_LIMIT=60

# ── Logging ───────────────────────────────────────────────────────────────────
# Path for the audit log file
GUNI_LOG_PATH=guni_audit.log

# ── Waitlist ──────────────────────────────────────────────────────────────────
# Path for waitlist JSON (use /tmp/ on Railway)
GUNI_WAITLIST_PATH=guni_waitlist.json

# ── Email (waitlist confirmation) ─────────────────────────────────────────────
# Gmail app password — myaccount.google.com → Security → App Passwords
# Leave blank to skip email sending
GUNI_EMAIL_FROM=your.email@gmail.com
GUNI_EMAIL_PASS=your-16-char-app-password

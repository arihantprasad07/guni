# Guni environment example
# Copy to `.env` and fill in the values you need.

# Core runtime
# Optional explicit directory for runtime files like logs and waitlist JSON.
GUNI_DATA_DIR=.guni
# Optional non-Mongo legacy path used only for backwards-compatible local runtime state.
GUNI_DB_PATH=.guni/guni.db
# Audit log file path.
GUNI_LOG_PATH=.guni/guni_audit.log
# Public waitlist storage path.
GUNI_WAITLIST_PATH=.guni/guni_waitlist.json
# Runtime event log path used by owner/admin summaries.
GUNI_EVENT_LOG_PATH=.guni/events.json
# Optional legacy key-storage path for older local flows.
GUNI_KEYS_PATH=.guni/guni_keys.json

# LLM configuration
# Primary provider used by the hosted scan service.
GUNI_LLM_PROVIDER=anthropic
# Model name used for the LLM reasoning layer.
GUNI_LLM_MODEL=claude-3-5-sonnet-latest
# Preferred generic LLM API key.
GUNI_LLM_API_KEY=
# Optional custom base URL for OpenAI-compatible gateways.
GUNI_LLM_BASE_URL=
# Provider-specific fallback keys that Guni also checks.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
GOOGLE_API_KEY=

# API access and rate limiting
# Comma-separated static API keys if you want to allow explicit keys in addition to DB-backed keys.
GUNI_API_KEYS=
# Allow open/demo mode on `/scan`, `/history`, and `/analyze` when no API key is supplied.
GUNI_ALLOW_OPEN_MODE=false
# Per-key request rate limit per minute.
GUNI_RATE_LIMIT=60

# Auth and roles
# Required in production to sign browser sessions safely.
GUNI_SESSION_SECRET=replace-me-with-a-long-random-secret
# Comma-separated admin emails that should receive admin role on signup.
GUNI_ADMIN_EMAILS=admin@example.com
# Comma-separated owner emails with elevated owner access.
GUNI_OWNER_EMAILS=owner@guni.dev

# Email delivery
# Sender address used for verification, welcome, billing, and pilot/admin emails.
GUNI_EMAIL_FROM=your.email@gmail.com
# App password or SMTP credential for the sender.
GUNI_EMAIL_PASS=your-16-char-app-password
# SMTP timeout in seconds.
GUNI_SMTP_TIMEOUT=10

# Billing
# Razorpay key ID for checkout link creation.
RAZORPAY_KEY_ID=
# Razorpay key secret for checkout link creation.
RAZORPAY_KEY_SECRET=
# Razorpay webhook signing secret for `POST /webhook/razorpay`.
RAZORPAY_WEBHOOK_SECRET=

# Database
# Primary MongoDB connection string used by the API.
GUNI_MONGO_URI=mongodb://localhost:27017/guni
# Optional fallback Mongo variable supported by the runtime.
MONGO_URI=
# Mongo database name override.
GUNI_MONGO_DB_NAME=guni
# Set to `true` to use in-memory mock Mongo for tests/local development.
GUNI_USE_MOCK_MONGO=false

# Environment markers
# Optional production marker checked by auth/runtime helpers.
GUNI_ENV=development
# Optional generic environment markers also checked for production detection.
ENV=development
APP_ENV=development

# Railway-provided variables
# Usually injected by Railway automatically; listed here for completeness because runtime helpers read them.
RAILWAY_ENVIRONMENT=
RAILWAY_PROJECT_ID=
RAILWAY_SERVICE_ID=
RAILWAY_VOLUME_MOUNT_PATH=
